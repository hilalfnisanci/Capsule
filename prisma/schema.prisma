// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Connection URL is intentionally omitted here; it is configured via
  // prisma.config.ts (Prisma v5+ allows this). Add url = env("DATABASE_URL")
  // if you need to use Prisma CLI commands without the config file.
}

// ------------------------------------------------------------------
// Enums
// ------------------------------------------------------------------

enum CapsuleStatus {
  LOCKED  // capsule is sealed; content cannot be read by recipients
  OPENED  // open date has passed and the capsule has been opened
}

enum CapsuleVisibility {
  PRIVATE // only the owner can view
  SHARED  // owner + explicitly invited users can view
  PUBLIC  // anyone can view (after open date)
}

enum MediaType {
  IMAGE
  AUDIO
  VIDEO
  DOCUMENT
}

// ------------------------------------------------------------------
// Models
// ------------------------------------------------------------------

model Capsule {
  id         String            @id @default(cuid())
  title      String
  description String?

  // Ownership
  userId     String            // references the auth user ID (e.g. NextAuth session user id)

  // Lifecycle
  status     CapsuleStatus     @default(LOCKED)
  visibility CapsuleVisibility @default(PRIVATE)

  // Scheduled unlock
  openDate   DateTime          // date/time after which the capsule may be opened
  openedAt   DateTime?         // set when the capsule is first opened; null while locked

  // Timestamps
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  // Relations
  media      CapsuleMedia[]
  sharedWith CapsuleShare[]

  @@index([userId])
  @@index([openDate])
  @@index([status])
}

// Stores uploaded media attached to a capsule.
// Actual file bytes live in object storage; this row holds metadata and the URL.
model CapsuleMedia {
  id         String    @id @default(cuid())
  capsuleId  String
  capsule    Capsule   @relation(fields: [capsuleId], references: [id], onDelete: Cascade)

  type       MediaType
  url        String    // storage URL (e.g. S3 presigned or CDN URL)
  filename   String
  mimeType   String
  sizeBytes  BigInt  // BIGINT to support files larger than 2 GB (INT overflows at ~2.147 GB)

  createdAt  DateTime  @default(now())

  @@index([capsuleId])
}

// Junction table for SHARED capsules.
// Each row grants read access to one user beyond the owner.
model CapsuleShare {
  id         String   @id @default(cuid())
  capsuleId  String
  capsule    Capsule  @relation(fields: [capsuleId], references: [id], onDelete: Cascade)

  userId     String   // invited user
  invitedAt  DateTime @default(now())

  @@unique([capsuleId, userId])
  @@index([userId])
}
